rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyAllowedMessageFields() {
      return request.resource.data.keys().hasOnly(['role', 'text', 'createdAt']);
    }

    function hasRequiredMessageFields() {
      return request.resource.data.keys().hasAll(['role', 'text', 'createdAt']);
    }

    function hasValidRole() {
      return request.resource.data.role in ['user', 'assistant'];
    }

    function hasValidText() {
      return request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000;
    }

    function hasValidCreatedAt() {
      return request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read, write: if false;

      match /messages/{messageId} {
        allow get, list: if isOwner(userId);

        allow create: if isOwner(userId)
          && hasRequiredMessageFields()
          && hasOnlyAllowedMessageFields()
          && hasValidRole()
          && hasValidText()
          && hasValidCreatedAt();

        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
